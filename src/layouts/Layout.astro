---
import "../styles/global.css";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <meta name="generator" content={Astro.generator} />
    <title>Desarrollador Full-Stack Freelance</title>
    <meta
      name="description"
      content="Desarrollador full-stack freelance. Python, PHP, Go, React, Next.js, Astro. Construyo aplicaciones web completas desde cero."
    />
    <meta property="og:title" content="Desarrollador Full-Stack Freelance" />
    <meta
      property="og:description"
      content="Desarrollador full-stack freelance. Python, PHP, Go, React, Next.js, Astro. Construyo aplicaciones web completas desde cero."
    />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Desarrollador Full-Stack Freelance" />
    <meta
      name="twitter:description"
      content="Desarrollador full-stack freelance. Construyo aplicaciones web completas."
    />

    <script is:inline>
      (function () {
        const stored = localStorage.getItem("theme");
        const prefersDark = window.matchMedia(
          "(prefers-color-scheme: dark)",
        ).matches;
        const theme = stored || (prefersDark ? "dark" : "light");
        document.documentElement.dataset.theme = theme;
        if (!stored && prefersDark) {
          document.documentElement.dataset.theme = "dark";
        }
      })();
    </script>

    <style is:inline>
      html {
        visibility: hidden;
      }
      html[data-theme] {
        visibility: visible;
      }
    </style>

  </head>
  <body>
    <slot />

    {/* Burbuja flotante @ con menú de contacto */}
    <div class="fixed bottom-6 right-6 z-50" id="contact-bubble-container">
      <button
        id="contact-bubble-btn"
        class="contact-bubble flex h-14 w-14 items-center justify-center rounded-full text-xl font-bold text-white/90 shadow-lg transition-all duration-300 hover:scale-110 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-glow"
        aria-label="Opciones de contacto"
        aria-expanded="false"
        aria-haspopup="true"
        type="button"
      >
        @
      </button>

      <div
        id="contact-bubble-menu"
        class="invisible absolute bottom-full right-0 mb-3 w-64 origin-bottom-right translate-y-2 rounded-2xl border border-white/[0.07] p-2 opacity-0 shadow-[0_16px_48px_rgba(0,0,0,0.4)] backdrop-blur-2xl transition-all duration-200"
        style="background: oklch(0.15 0.010 275 / 0.92)"
      >
        <a
          href="https://wa.me/573001234567"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-3 rounded-xl px-3 py-2.5 text-white/70 transition-colors duration-150 hover:bg-white/[0.08] hover:text-white"
        >
          <svg class="h-5 w-5 shrink-0" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.008-.57-.008-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          <div>
            <p class="text-sm font-medium">WhatsApp</p>
            <p class="text-xs text-white/40">Respuesta rápida</p>
          </div>
        </a>

        <a
          href="https://t.me/teban29"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-3 rounded-xl px-3 py-2.5 text-white/70 transition-colors duration-150 hover:bg-white/[0.08] hover:text-white"
        >
          <svg class="h-5 w-5 shrink-0" viewBox="0 0 24 24" fill="currentColor">
            <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
          </svg>
          <div>
            <p class="text-sm font-medium">Telegram</p>
            <p class="text-xs text-white/40">@teban29</p>
          </div>
        </a>

        <a
          href="mailto:ecardonagonzalez1029@gmail.com"
          class="flex items-center gap-3 rounded-xl px-3 py-2.5 text-white/70 transition-colors duration-150 hover:bg-white/[0.08] hover:text-white"
        >
          <svg class="h-5 w-5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect width="20" height="16" x="2" y="4" rx="2"/>
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
          </svg>
          <div>
            <p class="text-sm font-medium">Email</p>
            <p class="text-xs text-white/40">ecardonagonzalez1029@gmail.com</p>
          </div>
        </a>
      </div>
    </div>

    <script>
      (function() {
        const btn = document.getElementById('contact-bubble-btn');
        const menu = document.getElementById('contact-bubble-menu');
        if (!btn || !menu) return;

        function openMenu() {
          menu.classList.remove('invisible', 'opacity-0', 'translate-y-2');
          menu.classList.add('opacity-100', 'translate-y-0');
          btn.setAttribute('aria-expanded', 'true');
          btn.classList.add('scale-110');
        }

        function closeMenu() {
          menu.classList.add('invisible', 'opacity-0', 'translate-y-2');
          menu.classList.remove('opacity-100', 'translate-y-0');
          btn.setAttribute('aria-expanded', 'false');
          btn.classList.remove('scale-110');
        }

        btn.addEventListener('click', (e) => {
          e.stopPropagation();
          const isOpen = btn.getAttribute('aria-expanded') === 'true';
          isOpen ? closeMenu() : openMenu();
        });

        document.addEventListener('click', () => closeMenu());
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape') closeMenu();
        });
      })();
    </script>

    <style is:inline>
      .contact-bubble {
        background: linear-gradient(
          180deg,
          oklch(0.16 0.012 275 / 0.80) 0%,
          oklch(0.13 0.006 275 / 0.60) 100%
        );
        backdrop-filter: blur(40px) saturate(180%);
        -webkit-backdrop-filter: blur(40px) saturate(180%);
        box-shadow:
          0 8px 40px oklch(0 0 0 / 0.35),
          0 0 0 0.5px oklch(1 0 0 / 0.07) inset,
          0 1px 0 oklch(1 0 0 / 0.04) inset;
      }
    </style>
  </body>
</html>
