---
---

<section
  id="contacto"
  class="relative overflow-hidden bg-surface py-24 sm:py-32"
>
  <div class="mx-auto max-w-6xl px-6">
    <div class="mb-14 sm:mb-20">
      <p class="mb-3 font-mono text-xs font-medium tracking-wide text-primary">
        Contacto
      </p>
      <h2 class="text-balance font-sans text-[clamp(2rem,4vw,3rem)] font-bold leading-[1.12] tracking-[-0.02em] text-ink">
        Hablemos de tu proyecto
      </h2>
      <p class="mt-4 max-w-md text-base leading-relaxed text-muted">
        ¿Tienes una idea en mente o necesitas ayuda con algo existente?
        Escríbeme y respondemos en menos de 24 horas.
      </p>
    </div>

    <div class="grid gap-12 lg:grid-cols-5">
      {/* Columna izquierda: Info */}
      <div class="lg:col-span-2">
        <div class="space-y-8">
          {/* Estado */}
          <div class="rounded-2xl border border-border bg-bg p-6">
            <div class="mb-4 flex items-center gap-3">
              <span class="relative flex h-3 w-3">
                <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-green-500 opacity-75"></span>
                <span class="relative inline-flex h-3 w-3 rounded-full bg-green-500"></span>
              </span>
              <span class="text-sm font-semibold text-ink">Disponible para proyectos</span>
            </div>
            <p class="text-sm text-muted">
              Actualmente aceptando nuevos proyectos freelance. Tiempo de respuesta estimado: menos de 24h.
            </p>
          </div>

          {/* Detalles */}
          <div class="space-y-4">
            <a
              href="mailto:ecardonagonzalez1029@gmail.com"
              class="group flex items-center gap-4 rounded-2xl border border-border bg-bg p-4 transition-all duration-200 hover:border-primary/30 hover:shadow-sm"
            >
              <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary">
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect width="20" height="16" x="2" y="4" rx="2"/>
                  <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
                </svg>
              </div>
              <div class="min-w-0">
                <p class="text-xs font-medium text-muted">Email</p>
                <p class="truncate text-sm font-semibold text-ink group-hover:text-primary">ecardonagonzalez1029@gmail.com</p>
              </div>
            </a>

            <a
              href="https://github.com/teban29/"
              target="_blank"
              rel="noopener noreferrer"
              class="group flex items-center gap-4 rounded-2xl border border-border bg-bg p-4 transition-all duration-200 hover:border-primary/30 hover:shadow-sm"
            >
              <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary">
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                </svg>
              </div>
              <div class="min-w-0">
                <p class="text-xs font-medium text-muted">GitHub</p>
                <p class="truncate text-sm font-semibold text-ink group-hover:text-primary">github.com/teban29</p>
              </div>
            </a>

            <div class="flex items-center gap-4 rounded-2xl border border-border bg-bg p-4">
              <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary">
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/>
                  <circle cx="12" cy="10" r="3"/>
                </svg>
              </div>
              <div>
                <p class="text-xs font-medium text-muted">Ubicación</p>
                <p class="text-sm font-semibold text-ink">Cali, Colombia</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      {/* Columna derecha: Formulario */}
      <div class="lg:col-span-3 flex">
        <form
          id="contact-form"
          class="flex w-full flex-col rounded-2xl border border-border bg-bg p-6 sm:p-8"
          novalidate
        >
          <div class="mb-6 grid gap-6 sm:grid-cols-2 shrink-0">
            <div>
              <label for="nombre" class="mb-2 block text-sm font-medium text-ink">
                Nombre
              </label>
              <input
                type="text"
                id="nombre"
                name="nombre"
                required
                placeholder="Tu nombre"
                class="w-full rounded-xl border border-border bg-surface px-4 py-3 text-sm text-ink placeholder:text-muted outline-none transition-colors focus:border-primary focus:ring-1 focus:ring-primary/20"
              />
            </div>
            <div>
              <label for="email" class="mb-2 block text-sm font-medium text-ink">
                Email
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                placeholder="tu@email.com"
                class="w-full rounded-xl border border-border bg-surface px-4 py-3 text-sm text-ink placeholder:text-muted outline-none transition-colors focus:border-primary focus:ring-1 focus:ring-primary/20"
              />
            </div>
          </div>

          <div class="mb-6 flex flex-1 flex-col">
            <label for="mensaje" class="mb-2 block text-sm font-medium text-ink">
              Mensaje
            </label>
            <textarea
              id="mensaje"
              name="mensaje"
              required
              placeholder="Cuéntame sobre tu proyecto, tus objetivos y tu timeline..."
              class="w-full flex-1 resize-none rounded-xl border border-border bg-surface px-4 py-3 text-sm text-ink placeholder:text-muted outline-none transition-colors focus:border-primary focus:ring-1 focus:ring-primary/20"
            ></textarea>
          </div>

          <div class="flex shrink-0 items-center justify-between gap-4">
            <p id="form-status" class="text-sm font-medium" aria-live="polite"></p>
            <button
              type="submit"
              id="submit-btn"
              class="inline-flex items-center gap-2 rounded-full bg-primary px-7 py-3 text-sm font-semibold text-white transition-all duration-300 hover:bg-primary-glow hover:shadow-[0_0_30px_oklch(0.500_0.175_275_/_0.35)] disabled:opacity-50 disabled:cursor-not-allowed"
            >
              <span id="btn-text">Enviar mensaje</span>
              <svg id="btn-icon" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="22" y1="2" x2="11" y2="13"/>
                <polygon points="22 2 15 22 11 13 2 9 22 2"/>
              </svg>
              <svg id="btn-spinner" class="hidden h-4 w-4 animate-spin" viewBox="0 0 24 24" fill="none">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
              </svg>
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  function initContactForm() {
    const form = document.getElementById("contact-form") as HTMLFormElement | null;
    const status = document.getElementById("form-status");
    const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement | null;
    const btnText = document.getElementById("btn-text");
    const btnIcon = document.getElementById("btn-icon");
    const btnSpinner = document.getElementById("btn-spinner");

    if (!form || !status || !submitBtn || !btnText || !btnIcon || !btnSpinner) return;

    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      const formData = new FormData(form);
      const nombre = String(formData.get("nombre") || "").trim();
      const email = String(formData.get("email") || "").trim();
      const mensaje = String(formData.get("mensaje") || "").trim();

      if (!nombre || !email || !mensaje) {
        status.textContent = "Todos los campos son obligatorios.";
        status.className = "text-sm font-medium text-red-500";
        return;
      }

      const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      if (!emailRegex.test(email)) {
        status.textContent = "El correo electrónico no es válido.";
        status.className = "text-sm font-medium text-red-500";
        return;
      }

      submitBtn.disabled = true;
      btnText.textContent = "Enviando...";
      btnIcon.classList.add("hidden");
      btnSpinner.classList.remove("hidden");
      status.textContent = "";

      try {
        const response = await fetch("/api/contact", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ nombre, email, mensaje }),
        });

        const result = await response.json();

        if (response.ok) {
          status.textContent = "Mensaje enviado correctamente. Te responderé pronto.";
          status.className = "text-sm font-medium text-green-500";
          form.reset();
        } else {
          status.textContent = result.error || "Error al enviar. Intenta de nuevo.";
          status.className = "text-sm font-medium text-red-500";
        }
      } catch {
        status.textContent = "Error de conexión. Intenta de nuevo.";
        status.className = "text-sm font-medium text-red-500";
      } finally {
        submitBtn.disabled = false;
        btnText.textContent = "Enviar mensaje";
        btnIcon.classList.remove("hidden");
        btnSpinner.classList.add("hidden");
      }
    });
  }

  initContactForm();
</script>
