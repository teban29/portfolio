            desc: "Dockerización, CI/CD, configuración de servidores. Me aseguro de que tu aplicación llegue a producción sin drama.",
            tags: ["Docker", "CI/CD", "Linux"],
          },
        ].map((service) => (
          <div class="service-item group border-b border-border py-6 first:pt-0 last:border-b-0">
            <div class="flex gap-6">
              <span class="shrink-0 font-mono text-sm font-medium tabular-nums leading-relaxed text-primary/60 transition-colors duration-300 group-hover:text-primary">
