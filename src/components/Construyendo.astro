<script>
  function initReveal() {
    const section = document.getElementById("construyendo");
    if (!section) return;

    const cards = section.querySelectorAll(".build-card, .build-card-full");
    const progressBars = section.querySelectorAll(".build-progress");

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
          }
        });
      },
      { threshold: 0.1, rootMargin: "0px 0px -30px 0px" },
    );

    cards.forEach((card, i) => {
      card.style.setProperty("--card-index", String(i));
      observer.observe(card);
    });

    progressBars.forEach((bar) => {
      const el = bar as HTMLElement;
      const progress = el.style.getPropertyValue("--progress");
      el.style.width = "0%";
      const progObserver = new IntersectionObserver(
        ([entry]) => {
          if (entry.isIntersecting) {
            setTimeout(() => {
              el.style.width = progress;
            }, 300);
          }
        },
        { threshold: 0.3 },
      );
      progObserver.observe(el);
    });
  }

  initReveal();
</script>

<style is:inline>
  .build-card,
  .build-card-full {
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.5s ease, transform 0.5s cubic-bezier(0.22, 1, 0.36, 1), border-color 0.3s, box-shadow 0.3s;
    transition-delay: calc(var(--card-index, 0) * 0.08s);
  }

  .build-card.is-visible,
  .build-card-full.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .build-progress {
    width: 0%;
    transition: width 1s cubic-bezier(0.22, 1, 0.36, 1);
  }

  @media (prefers-reduced-motion: reduce) {
    .build-card,
    .build-card-full {
      opacity: 1;
      transform: none;
      transition: none;
    }

    .build-progress {
      transition: none;
      width: var(--progress) !important;
    }
  }
</style>
