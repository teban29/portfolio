<canvas
  id="particle-canvas"
  class="absolute inset-0 h-full w-full"
  aria-hidden="true"
></canvas>

<script>
  function initParticleNetwork() {
    const canvas = document.getElementById(
      "particle-canvas",
    ) as HTMLCanvasElement | null;
    if (!canvas) return;

    const ctx = canvas.getContext("2d");
    if (!ctx) return;

    const prefersReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;

    const CONFIG = {
      count: prefersReducedMotion ? 20 : 55,
      connectDistance: 130,
      particleSize: 1.4,
      baseSpeed: 0.25,
      mouseRadius: 160,
      mouseForce: 0.15,
    };

    const mouse = { x: -1000, y: -1000 };
    let particles: Particle[] = [];
    let animationId = 0;

    interface Particle {
      x: number;
      y: number;
      vx: number;
      vy: number;
    }

    function createParticles(w: number, h: number): Particle[] {
      const arr: Particle[] = [];
      for (let i = 0; i < CONFIG.count; i++) {
        arr.push({
          x: Math.random() * w,
          y: Math.random() * h,
          vx: (Math.random() - 0.5) * CONFIG.baseSpeed,
          vy: (Math.random() - 0.5) * CONFIG.baseSpeed,
        });
      }
      return arr;
    }

    function resize() {
      const dpr = window.devicePixelRatio || 1;
      const rect = canvas!.getBoundingClientRect();
      canvas!.width = rect.width * dpr;
      canvas!.height = rect.height * dpr;
      ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);
      particles = createParticles(rect.width, rect.height);
    }

    function getParticleColor(): string {
      const isDark = document.documentElement.dataset.theme === "dark";
      return isDark
        ? "oklch(0.620 0.120 160)"
        : "oklch(0.560 0.130 160)";
    }

    function draw() {
      if (!ctx || !canvas) return;
      const w = canvas.getBoundingClientRect().width;
      const h = canvas.getBoundingClientRect().height;
      const particleColor = getParticleColor();

      ctx.clearRect(0, 0, w, h);

      for (const p of particles) {
        const dx = p.x - mouse.x;
        const dy = p.y - mouse.y;
        const dist = Math.sqrt(dx * dx + dy * dy);

        if (dist < CONFIG.mouseRadius) {
          const force =
            ((CONFIG.mouseRadius - dist) / CONFIG.mouseRadius) *
            CONFIG.mouseForce;
          p.vx += (dx / (dist + 0.01)) * force;
          p.vy += (dy / (dist + 0.01)) * force;
        }

        p.vx *= 0.995;
        p.vy *= 0.995;

        p.x += p.vx;
        p.y += p.vy;

        if (p.x < -40) p.x = w + 40;
        if (p.x > w + 40) p.x = -40;
        if (p.y < -40) p.y = h + 40;
        if (p.y > h + 40) p.y = -40;

        ctx.beginPath();
        ctx.arc(p.x, p.y, CONFIG.particleSize, 0, Math.PI * 2);
        ctx.fillStyle = particleColor;
        ctx.globalAlpha = 0.45;
        ctx.fill();
      }

      for (let i = 0; i < particles.length; i++) {
        for (let j = i + 1; j < particles.length; j++) {
          const dx = particles[i].x - particles[j].x;
          const dy = particles[i].y - particles[j].y;
          const dist = Math.sqrt(dx * dx + dy * dy);
          if (dist < CONFIG.connectDistance) {
            const alpha = 0.12 * (1 - dist / CONFIG.connectDistance);
            ctx.beginPath();
            ctx.moveTo(particles[i].x, particles[i].y);
            ctx.lineTo(particles[j].x, particles[j].y);
            ctx.strokeStyle = particleColor;
            ctx.globalAlpha = alpha;
            ctx.lineWidth = 0.6;
            ctx.stroke();
          }
        }
      }

      ctx.globalAlpha = 1;
      animationId = requestAnimationFrame(draw);
    }

    window.addEventListener("resize", resize);

    document.addEventListener("mousemove", (e) => {
      const rect = canvas!.getBoundingClientRect();
      mouse.x = e.clientX - rect.left;
      mouse.y = e.clientY - rect.top;
    });

    document.addEventListener("mouseleave", () => {
      mouse.x = -1000;
      mouse.y = -1000;
    });

    resize();
    draw();

    return () => {
      cancelAnimationFrame(animationId);
      window.removeEventListener("resize", resize);
    };
  }

  initParticleNetwork();
</script>
