---
import ThemeToggle from "./ThemeToggle.astro";
---

<nav
  id="dynamic-island"
  class="fixed left-1/2 top-4 z-50 -translate-x-1/2"
  aria-label="Navegación principal"
>
  <div
    class="island-pill flex items-center gap-0.5 rounded-full px-2 py-2 text-sm font-medium"
  >
    <a
      href="#hero"
      class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full text-xs font-bold transition-colors duration-200"
      aria-label="Inicio"
      data-nav="hero"
    >
      E
    </a>

    <div class="mx-0.5 hidden h-5 w-px shrink-0 bg-[var(--glass-separator)] sm:block" aria-hidden="true"></div>

    <div class="nav-links hidden items-center sm:flex">
      <a href="#servicios" data-nav="servicios" class="nav-link rounded-full px-3 py-1.5 transition-colors duration-200">Servicios</a>
      <a href="#proyectos" data-nav="proyectos" class="nav-link rounded-full px-3 py-1.5 transition-colors duration-200">Proyectos</a>
      <a href="#tecnologias" data-nav="tecnologias" class="nav-link rounded-full px-3 py-1.5 transition-colors duration-200">Tecnologías</a>
      <a href="#sobre-mi" data-nav="sobre-mi" class="nav-link rounded-full px-3 py-1.5 transition-colors duration-200">Sobre mí</a>
      <a href="#contacto" data-nav="contacto" class="nav-link rounded-full px-3 py-1.5 transition-colors duration-200">Contacto</a>
    </div>

    <div class="relative flex items-center">
      <button
        id="nav-more"
        class="flex h-8 w-8 items-center justify-center rounded-full transition-colors duration-200 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-glow"
        aria-label="Más secciones"
        aria-expanded="false"
        aria-haspopup="true"
        type="button"
      >
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
          <circle cx="5" cy="12" r="2" />
          <circle cx="12" cy="12" r="2" />
          <circle cx="19" cy="12" r="2" />
        </svg>
      </button>

      <div
        id="nav-dropdown"
        class="invisible absolute right-0 top-full mt-3 w-56 origin-top-right translate-y-2 rounded-2xl border p-2 opacity-0 backdrop-blur-2xl transition-all duration-200"
      >
        <a href="#servicios" data-nav="servicios" class="nav-link flex items-center rounded-xl px-3 py-2.5 transition-colors duration-150 sm:hidden">Servicios</a>
        <a href="#proyectos" data-nav="proyectos" class="nav-link flex items-center rounded-xl px-3 py-2.5 transition-colors duration-150 sm:hidden">Proyectos</a>
        <a href="#tecnologias" data-nav="tecnologias" class="nav-link flex items-center rounded-xl px-3 py-2.5 transition-colors duration-150 sm:hidden">Tecnologías</a>
        <a href="#sobre-mi" data-nav="sobre-mi" class="nav-link flex items-center rounded-xl px-3 py-2.5 transition-colors duration-150 sm:hidden">Sobre mí</a>
        <a href="#contacto" data-nav="contacto" class="nav-link flex items-center rounded-xl px-3 py-2.5 transition-colors duration-150 sm:hidden">Contacto</a>
        <div class="my-1.5 border-t border-[var(--glass-dropdown-border)] sm:hidden"></div>
        <a href="#como-trabajo" data-nav="como-trabajo" class="nav-link flex items-center rounded-xl px-3 py-2.5 transition-colors duration-150">Cómo Trabajo</a>
        <a href="#hosting" data-nav="hosting" class="nav-link flex items-center rounded-xl px-3 py-2.5 transition-colors duration-150">Hosting & DevOps</a>
        <a href="#construyendo" data-nav="construyendo" class="nav-link flex items-center rounded-xl px-3 py-2.5 transition-colors duration-150">Actualmente Construyendo</a>
        <a href="#faq" data-nav="faq" class="nav-link flex items-center rounded-xl px-3 py-2.5 transition-colors duration-150">FAQ</a>
      </div>
    </div>

    <div class="mx-0.5 hidden h-5 w-px shrink-0 bg-[var(--glass-separator)] sm:block" aria-hidden="true"></div>

    <ThemeToggle />
  </div>
</nav>

<script>
  function initNavbar() {
    const nav = document.getElementById("dynamic-island");
    const moreBtn = document.getElementById("nav-more");
    const dropdown = document.getElementById("nav-dropdown");
    if (!nav) return;

    const links = nav.querySelectorAll<HTMLAnchorElement>("[data-nav]");

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            const id = entry.target.id;
            links.forEach((l) => {
              const isActive = l.dataset.nav === id;
              l.classList.toggle("active-link", isActive);
            });
          }
        }
      },
      { rootMargin: "-40% 0px -55% 0px" },
    );

    const sectionIds = [
      "hero", "servicios", "proyectos", "como-trabajo", "hosting",
      "tecnologias", "construyendo", "sobre-mi", "faq", "contacto",
    ];

    for (const id of sectionIds) {
      const el = document.getElementById(id);
      if (el) observer.observe(el);
    }

    function openDropdown() {
      if (!dropdown || !moreBtn) return;
      dropdown.classList.remove("invisible", "opacity-0", "translate-y-2");
      dropdown.classList.add("opacity-100", "translate-y-0");
      moreBtn.setAttribute("aria-expanded", "true");
      moreBtn.classList.add("bg-[var(--glass-separator)]");
    }

    function closeDropdown() {
      if (!dropdown || !moreBtn) return;
      dropdown.classList.add("invisible", "opacity-0", "translate-y-2");
      dropdown.classList.remove("opacity-100", "translate-y-0");
      moreBtn.setAttribute("aria-expanded", "false");
      moreBtn.classList.remove("bg-[var(--glass-separator)]");
    }

    if (moreBtn && dropdown) {
      moreBtn.addEventListener("click", (e) => {
        e.stopPropagation();
        const isOpen = moreBtn.getAttribute("aria-expanded") === "true";
        isOpen ? closeDropdown() : openDropdown();
      });

      dropdown.addEventListener("click", (e) => {
        const link = (e.target as HTMLElement).closest("a");
        if (link) closeDropdown();
      });

      document.addEventListener("click", () => closeDropdown());
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") closeDropdown();
      });
    }
  }

  initNavbar();
</script>

<style is:inline>
  .island-pill {
    background: var(--glass-bg);
    backdrop-filter: blur(40px) saturate(180%);
    -webkit-backdrop-filter: blur(40px) saturate(180%);
    box-shadow: var(--glass-shadow);
    will-change: transform;
    color: var(--glass-text);
  }

  .island-pill a,
  .island-pill button:not(#theme-toggle) {
    color: var(--glass-text-muted);
    transition: color 0.2s, background 0.2s;
  }

  .island-pill a:hover,
  .island-pill button:not(#theme-toggle):hover {
    color: var(--glass-text);
    background: var(--glass-hover-bg);
  }

  .island-pill .nav-link.active-link,
  .island-pill [data-nav].active-link {
    color: var(--glass-text);
    background: var(--glass-hover-bg);
  }

  .nav-link {
    white-space: nowrap;
  }

  #nav-dropdown {
    background: var(--glass-dropdown-bg);
    border-color: var(--glass-dropdown-border);
    box-shadow: var(--glass-dropdown-shadow);
  }

  #nav-dropdown a {
    color: var(--glass-text-muted);
  }

  #nav-dropdown a:hover {
    color: var(--glass-text);
    background: var(--glass-dropdown-hover-bg);
  }

  @media (prefers-reduced-motion: reduce) {
    .island-pill {
      backdrop-filter: blur(40px);
      -webkit-backdrop-filter: blur(40px);
    }
  }
</style>
