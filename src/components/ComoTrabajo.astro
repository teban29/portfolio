<section
  id="como-trabajo"
  class="relative bg-bg py-24 sm:py-32"
>
  <div class="mx-auto max-w-6xl px-6">
    <div class="mb-14 sm:mb-20">
      <p class="mb-3 font-mono text-xs font-medium tracking-wide text-primary">
        Cómo Trabajo
      </p>
      <h2 class="text-balance font-sans text-[clamp(2rem,4vw,3rem)] font-bold leading-[1.12] tracking-[-0.02em] text-ink">
        De la idea<br />a producción
      </h2>
      <p class="mt-4 max-w-md text-base leading-relaxed text-muted">
        Un proceso directo, sin grilla corporativa. Comunicación clara, entregas frecuentes, cero sorpresas.
      </p>
    </div>

    <div class="timeline relative">
      <div class="timeline-line absolute hidden sm:block" aria-hidden="true">
        <div class="timeline-line-progress absolute inset-0 origin-left"></div>
      </div>

      <div class="grid gap-8 sm:grid-cols-5 sm:gap-4 lg:gap-6">
        {
          [
            {
              title: "Escucho el problema real",
              desc: "No me pides una landing page. Cuéntame qué querés lograr. Defino el alcance y lo que realmente mueve la aguja para tu negocio.",
            },
            {
              title: "Elijo el stack correcto",
              desc: "Para cada proyecto elijo las herramientas que mejor se ajustan — no las que están de moda. Django, Go, Astro: cada una donde brilla.",
            },
            {
              title: "Construyo en ciclos cortos",
              desc: "Nada de meses en silencio. Desarrollo iterativo con entregas cada una o dos semanas. Ves progreso real, no slides.",
            },
            {
              title: "Ajusto sobre la marcha",
              desc: "El feedback no es un evento al final, es parte del proceso. Comunicación directa, cambios pequeños no descarrilan nada.",
            },
            {
              title: "Entrego y me quedo cerca",
              desc: "Deploy, documentación, monitoreo. Y después, si necesitás ajustes o nuevas features, ya conozco el código como la palma de mi mano.",
            },
          ].map((phase, i) => (
            <div class="process-phase group relative flex gap-5 sm:flex-col sm:gap-4 sm:text-center"
              style={`--phase-index: ${i}`}>
              <div class="flex shrink-0 flex-col items-center sm:flex-row sm:justify-center">
                <div class="process-dot relative z-10 flex h-5 w-5 shrink-0 items-center justify-center sm:h-3.5 sm:w-3.5">
                  <span class="absolute inset-0 rounded-full bg-primary/20"></span>
                  <span class="process-dot-core absolute inset-0 rounded-full bg-primary shadow-[0_0_12px_var(--primary-glow)] opacity-0"></span>
                </div>
                <div class="h-full w-px shrink-0 bg-border sm:hidden" aria-hidden="true"></div>
              </div>

              <div class="min-w-0 pb-6 sm:pb-0 sm:pt-5">
                <h3 class="font-sans text-base font-semibold leading-snug text-ink sm:text-sm lg:text-base">
                  {phase.title}
                </h3>
                <p class="mt-2 max-w-xs text-sm leading-relaxed text-muted sm:mx-auto sm:text-xs lg:text-sm">
                  {phase.desc}
                </p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<script>
  function initTimeline() {
    const section = document.getElementById("como-trabajo");
    if (!section) return;

    const phases = section.querySelectorAll(".process-phase");
    const progressBar = section.querySelector(".timeline-line-progress") as HTMLElement | null;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          const phase = entry.target as HTMLElement;
          if (entry.isIntersecting) {
            phase.classList.add("is-active");
          }
        });
      },
      { threshold: 0.3, rootMargin: "0px 0px -20% 0px" },
    );

    phases.forEach((phase, i) => {
      phase.style.setProperty("--phase-index", String(i));
      observer.observe(phase);
    });

    if (progressBar) {
      const sectionObserver = new IntersectionObserver(
        ([entry]) => {
          if (entry.isIntersecting) {
            const ratio = Math.min(1, entry.intersectionRatio * 1.3);
            progressBar.style.transform = `scaleX(${ratio})`;
          }
        },
        { threshold: Array.from({ length: 20 }, (_, i) => i / 20) },
      );
      sectionObserver.observe(section);
    }
  }

  initTimeline();
</script>

<style is:inline>
  .timeline {
    container-type: inline-size;
  }

  .timeline-line {
    top: 6px;
    left: 8px;
    right: 8px;
    height: 2px;
    background: var(--border);
    border-radius: 1px;
  }

  .timeline-line-progress {
    background: linear-gradient(90deg, var(--primary), var(--primary-glow));
    border-radius: 1px;
    transform: scaleX(0);
    transition: transform 0.3s ease-out;
  }

  .process-phase {
    opacity: 0.4;
    transition: opacity 0.5s ease;
  }

  .process-phase.is-active {
    opacity: 1;
  }

  .process-phase.is-active .process-dot-core {
    opacity: 1;
    animation: dotGlowPulse 2s ease-in-out infinite;
    animation-delay: calc(var(--phase-index, 0) * 0.15s);
  }

  .process-dot {
    transition: transform 0.3s ease;
  }

  .process-phase:hover .process-dot {
    transform: scale(1.4);
  }

  @keyframes dotGlowPulse {
    0%, 100% {
      box-shadow: 0 0 12px var(--primary-glow);
    }
    50% {
      box-shadow: 0 0 24px var(--primary-glow), 0 0 40px var(--primary-glow);
    }
  }

  @media (max-width: 639px) {
    .timeline-line {
      display: none;
    }

    .process-phase {
      opacity: 1;
      transform: translateY(16px);
      transition: opacity 0.5s ease, transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
      transition-delay: calc(var(--phase-index, 0) * 0.1s);
    }

    .process-phase.is-active {
      opacity: 1;
      transform: translateY(0);
    }

    .process-dot-core {
      opacity: 1;
    }

    .process-phase.is-active .process-dot-core {
      animation: dotGlowPulse 2s ease-in-out infinite;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .process-phase {
      opacity: 1;
      transition: none;
    }

    .process-dot-core {
      opacity: 1;
      animation: none;
    }

    .timeline-line-progress {
      transition: none;
    }
  }
</style>
