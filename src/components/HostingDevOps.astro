---
---

<section
  id="hosting"
  class="relative overflow-hidden bg-surface py-24 sm:py-32"
>
  <div class="mx-auto max-w-6xl px-6">
    <div class="mb-14 sm:mb-20">
      <p class="mb-3 font-mono text-xs font-medium tracking-wide text-primary">
        Infraestructura
      </p>
      <h2 class="text-balance font-sans text-[clamp(2rem,4vw,3rem)] font-bold leading-[1.12] tracking-[-0.02em] text-ink">
        Hosting & DevOps
      </h2>
      <p class="mt-4 max-w-md text-base leading-relaxed text-muted">
        No solo escribo código: despliego, monitoreo y mantengo aplicaciones en producción con infraestructura robusta.
      </p>
    </div>

    <div class="grid items-start gap-8 lg:grid-cols-[1.1fr_0.9fr]">
      <div class="space-y-6">
      <div class="overflow-hidden rounded-2xl border border-border bg-surface-alt shadow-xl">
        <div class="flex items-center gap-2 border-b border-white/10 px-4 py-3">
          <div class="flex gap-1.5">
            <span class="h-3 w-3 rounded-full bg-red-500"></span>
            <span class="h-3 w-3 rounded-full bg-yellow-500"></span>
            <span class="h-3 w-3 rounded-full bg-green-500"></span>
          </div>
          <span class="ml-2 text-xs font-mono text-muted-on-dark/60">esteban@server:~</span>
        </div>

        <div class="p-4 font-mono text-sm leading-relaxed sm:p-5">
          <div class="mb-1 flex items-center gap-2">
            <span class="text-green-500">➜</span>
            <span class="text-blue-500">~</span>
            <span class="text-gray-200">docker ps</span>
          </div>
          <div class="mb-3 text-gray-200">
            <div class="terminal-row terminal-row-header">
              <span>CONTAINER</span>
              <span>STATUS</span>
              <span>PORTS</span>
              <span>NAME</span>
            </div>
            <div class="terminal-row">
              <span class="text-gray-200">app-prod</span>
              <span class="text-green-500">Up 14d</span>
              <span class="text-gray-200">3000:3000</span>
              <span class="text-muted-on-dark/60">web</span>
            </div>
            <div class="terminal-row">
              <span class="text-gray-200">nginx</span>
              <span class="text-green-500">Up 14d</span>
              <span class="text-gray-200">80:80, 443:443</span>
              <span class="text-muted-on-dark/60">proxy</span>
            </div>
            <div class="terminal-row">
              <span class="text-gray-200">postgres</span>
              <span class="text-green-500">Up 14d</span>
              <span class="text-gray-200">5432:5432</span>
              <span class="text-muted-on-dark/60">db</span>
            </div>
          </div>

          <div class="mb-1 flex items-center gap-2">
            <span class="text-green-500">➜</span>
            <span class="text-blue-500">~</span>
            <span class="text-gray-200">uptime</span>
          </div>
          <div class="mb-3 text-xs text-gray-200">
            14:32:07 up 14 days, 6:42, 1 user, load average: 0.12, 0.08, 0.05
          </div>

          <div class="mb-1 flex items-center gap-2">
            <span class="text-green-500">➜</span>
            <span class="text-blue-500">~</span>
            <span class="text-gray-200">certbot certificates</span>
          </div>
          <div class="mb-3 text-xs text-gray-200">
            <span class="text-green-500">✓</span> example.com — expires in 72 days<br/>
            <span class="text-green-500">✓</span> api.example.com — expires in 72 days
          </div>

          <div class="mb-1 flex items-center gap-2">
            <span class="text-green-500">➜</span>
            <span class="text-blue-500">~</span>
            <span class="text-gray-200">curl -s https://api.example.com/health</span>
          </div>
          <div class="text-xs text-gray-200">
            {`{"status":"ok","version":"2.4.1","uptime":"14d 6h 42m"}`}
          </div>

          <div class="mt-3 flex items-center gap-2">
            <span class="text-green-500">➜</span>
            <span class="text-blue-500">~</span>
            <span class="inline-block h-4 w-2 animate-pulse bg-gray-200"></span>
          </div>
        </div>
      </div>
      <div class="rounded-2xl border border-border bg-bg p-6 transition-all duration-200 hover:border-primary/20 hover:shadow-sm">
        <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-xl bg-primary/10 text-primary">
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect width="20" height="8" x="2" y="2" rx="2" ry="2"/>
            <rect width="20" height="8" x="2" y="14" rx="2" ry="2"/>
            <line x1="6" x2="6.01" y1="6" y2="6"/>
            <line x1="6" x2="6.01" y1="18" y2="18"/>
          </svg>
        </div>
        <h3 class="mb-2 text-lg font-semibold text-ink">VPS & Servidores Dedicados</h3>
        <p class="text-sm leading-relaxed text-muted">
          Configuración y mantenimiento de servidores VPS (DigitalOcean, Hetzner, AWS Lightsail).
          Optimización de recursos, hardening de seguridad y monitoreo continuo.
        </p>
      </div>
    </div>

    <div class="space-y-6">
      <div class="rounded-2xl border border-border bg-bg p-6 transition-all duration-200 hover:border-primary/20 hover:shadow-sm">
          <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-xl bg-primary/10 text-primary">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/>
              <path d="m9 12 2 2 4-4"/>
            </svg>
          </div>
          <h3 class="mb-2 text-lg font-semibold text-ink">SSL & Seguridad</h3>
          <p class="text-sm leading-relaxed text-muted">
            Implementación de certificados SSL/TLS con Let's Encrypt, configuración de firewalls (UFW),
            protección DDoS básica y auditorías de seguridad periódicas.
          </p>
        </div>

        <div class="rounded-2xl border border-border bg-bg p-6 transition-all duration-200 hover:border-primary/20 hover:shadow-sm">
          <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-xl bg-primary/10 text-primary">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/>
              <path d="M3 3v5h5"/>
              <path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16"/>
              <path d="M16 16h5v5"/>
            </svg>
          </div>
          <h3 class="mb-2 text-lg font-semibold text-ink">CI/CD & Automatización</h3>
          <p class="text-sm leading-relaxed text-muted">
            Pipelines de despliegue continuo con GitHub Actions. Deploys automatizados, tests en cada push,
            rollback instantáneo y notificaciones en caso de fallos.
          </p>
        </div>

        <div class="rounded-2xl border border-border bg-bg p-6 transition-all duration-200 hover:border-primary/20 hover:shadow-sm">
          <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-xl bg-primary/10 text-primary">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M2 12h10"/>
              <path d="M9 4v16"/>
              <path d="m3 9 3 3-3 3"/>
              <path d="M14 8V5c0-1.1.9-2 2-2h4a2 2 0 0 1 2 2v3"/>
              <path d="M14 16v3c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2v-3"/>
              <rect width="8" height="8" x="14" y="8" rx="1"/>
            </svg>
          </div>
          <h3 class="mb-2 text-lg font-semibold text-ink">Backups & Monitoreo</h3>
          <p class="text-sm leading-relaxed text-muted">
            Backups automatizados diarios con retención configurable. Monitoreo de uptime con UptimeRobot
            y alertas por email/Telegram ante cualquier anomalía.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<style is:inline>
  .terminal-row {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr auto;
    gap: 0.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    padding-top: 0.375rem;
    padding-bottom: 0.375rem;
    font-size: 0.75rem;
  }
  .terminal-row-header {
    border-top: none;
    padding-top: 0;
    padding-bottom: 0;
    margin-bottom: 0.25rem;
    font-weight: 600;
  }
</style>
